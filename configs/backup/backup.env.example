# Copy to ~/.config/dotfiles/backup.env and adjust.
# chmod 600 ~/.config/dotfiles/backup.env

# Borg repository (local path or ssh://user@host/./path)
BACKUP_REPO="$HOME/backups/borg"

# Passphrase for repo encryption (required for init). Leave empty only for testing.
BORG_PASSPHRASE="change-me"

# Space-separated absolute paths to include
BACKUP_PATHS="$HOME /etc"

# Archive name prefix (hostname-YYYY-MM-DDTHH:MM:SS appended automatically)
BACKUP_PREFIX="{hostname}"

# Prune policy (keep last N daily / weekly / monthly)
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# Skip automatic (timer/hook) backups if last create was fewer than N seconds ago
MIN_INTERVAL_SEC=3600
